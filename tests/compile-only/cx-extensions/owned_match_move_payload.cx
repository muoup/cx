struct Resource : @nodrop {
    int data;
};

enum union MaybeResource : @nodrop {
    none :: void,
    some :: Resource
};

void Resource::drop(this) safe {
    @unsafe {
        @leak(this);
    };
}

int main() {
    MaybeResource maybe = MaybeResource::some((Resource) {
        .data = 1
    });
    match (move maybe) {
        MaybeResource::some(inner) => {
            Resource value = move inner;
            value.drop();
        }
        MaybeResource::none() => {}
    }
    return 0;
}
