struct box : @nodrop {
    int* ptr;
};

box box::new(int init) safe {
    @unsafe {
        box b = (box) {
            .ptr = malloc(sizeof(int))
        };

        *(b.ptr) = init;
        return move b;
    };
}

void box::drop(*this) {
    @unsafe {
        free(this.ptr);
        @leak(this);
    };
}

int main() {
    box value = box::new(3);
    value.drop();
    return 0;
}

#include <stdlib.h>
