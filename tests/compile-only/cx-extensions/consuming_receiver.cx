struct Resource : @nodrop {
    int data;
};

Resource make_resource() {
    return (Resource) {
        .data = 1
    };
}

void Resource::drop(*this) safe {
    @unsafe {
        @leak(this);
    };
}

int main() {
    Resource value = make_resource();
    value.drop();
    make_resource().drop();
    return 0;
}
