import std::vector;

struct Resource : @nodrop {
    int data;
};

void destroy(Resource value) {
    @leak(value);
}

int main() {
    std::vector::vector<Resource> values = std::vector::vector<Resource>::new<Resource>();
    Resource value = (Resource) {
        .data = 11
    };

    values.push<Resource>(move value);
    values.drop_with<Resource>(destroy);
    return 0;
}
