import std::vector;
import std::io;
import std::ref;
import std::optional;

int main() {
    opt<ref<int>> maybe_value;
    
    vector<int> vec = vector<int>::new<int>();
    
    vec.push<int>(1);
    vec.push<int>(2);
    vec.push<int>(3);

    printf("Vector length: %zu\n", vec.length);
    printf("Vector capacity: %zu\n", vec.capacity);
    
    printf("vec[0]: %d\n", vec.at<int>(0).unwrap().deref());
    
    vec.drop<int>();
}