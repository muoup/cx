#include <stdio.h>

struct templated_object<T> : @nodrop {
    T value;
};

void templated_object<T>::drop<T>(*this) {
    printf("drop templated_object\n");
    @leak(this);
}

int main() {
    templated_object<int> object = (templated_object<int>) {
        .value = 3
    };
    object.drop<int>();
}
