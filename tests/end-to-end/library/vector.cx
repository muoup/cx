import std::vector;
import std::io;
import std::optional;

int main() {
    std::vector::vector<int> vec = std::vector::vector<int>::new<int>();
    
    vec.push<int>(1);
    vec.push<int>(2);
    vec.push<int>(3);

    std::io::printf("Vector length: %zu\n", vec.length);
    std::io::printf("Vector capacity: %zu\n", vec.capacity);
    
    std::optional::opt<int&> maybe_value = vec.at<int>(0);
    int value = maybe_value.unwrap<int&>();
    
    std::io::printf("vec[0]: %d\n", value);
    vec.drop<int>();
}
