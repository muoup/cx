import std::file;
import std::io;
import std::optional;
import std::string;

#include <stdio.h>

i32 main() {
    std::file::file f = std::file::file::open("end-to-end/library/file_read_to_string.txt", "r").unwrap();
    std::string::string s = f.read_to_string();

    std::io::printf("%s", @unsafe((const char*)s.as_str()));

    f.close();
    s.drop();

    return 0;
}
