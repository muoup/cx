import std::optional;
import std::io;

int add_one(i8 x) {
    return x + 1;
}

int main() {
    std::optional::opt<i8> a = std::optional::opt<i8>::some(42);
    std::optional::opt<i8> b = std::optional::opt<i8>::none();

    std::io::printf("a is some: %b\n", a.is_some<i8>());
    std::io::printf("b is some: %b\n", b.is_some<i8>());

    std::io::printf("a unwrap_or 100: %d\n", a.unwrap_or<i8>(100));
    std::io::printf("b unwrap_or 100: %d\n", b.unwrap_or<i8>(100));

    a = std::optional::opt<i8>::some(42);
    b = std::optional::opt<i8>::none();

    std::optional::opt<int> c = a.map<i8, int>(add_one);
    std::optional::opt<int> d = b.map<i8, int>(add_one);

    std::io::printf("c is some: %b\n", c.is_some<int>());
    std::io::printf("d is some: %b\n", d.is_some<int>());

    std::io::printf("c unwrap: %d\n", c.unwrap<int>());
    std::io::printf("d unwrap: %d\n", d.unwrap<int>());
}
