import std::optional;
import std::io;

int add_one(i8 x) {
    return x + 1;
}

int main() {
    opt<i8> a = opt<i8>::some(42);
    opt<i8> b = opt<i8>::none();

    printf("a is some: %b\n", a.is_some<i8>());
    printf("b is some: %b\n", b.is_some<i8>());

    printf("a unwrap_or 100: %d\n", a.unwrap_or<i8>(100));
    printf("b unwrap_or 100: %d\n", b.unwrap_or<i8>(100));

    a = opt<i8>::some(42);
    b = opt<i8>::none();

    opt<int> c = a.map<i8, int>(add_one);
    opt<int> d = b.map<i8, int>(add_one);

    printf("c is some: %b\n", c.is_some<int>());
    printf("d is some: %b\n", d.is_some<int>());

    printf("c unwrap: %d\n", c.unwrap<int>());
    printf("d unwrap: %d\n", d.unwrap<int>());
}